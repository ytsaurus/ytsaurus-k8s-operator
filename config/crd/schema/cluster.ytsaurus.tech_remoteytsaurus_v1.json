{
  "description": "RemoteYtsaurus is the Schema for the remoteytsauruses API",
  "type": "object",
  "properties": {
    "apiVersion": {
      "description": "APIVersion defines the versioned schema of this representation of an object.",
      "type": "string"
    },
    "kind": {
      "description": "Kind is a string value representing the REST resource this object represents.",
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "description": "RemoteYtsaurusSpec defines the desired state of RemoteYtsaurus",
      "type": "object",
      "properties": {
        "cellTag": {
          "description": "Deprecated: use primaryMaster.cellTag instead.",
          "type": "integer",
          "maximum": 61440,
          "minimum": 1
        },
        "cellTagMasterCaches": {
          "description": "Deprecated: have no effect.",
          "type": "integer"
        },
        "hostAddresses": {
          "description": "Deprecated: use primaryMaster.hostAddresses instead.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hostAddressesMasterCaches": {
          "description": "Deprecated: use masterCaches.hostAddresses instead.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "masterCaches": {
          "type": "object",
          "properties": {
            "hostAddresses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "x-kubernetes-list-type": "set"
            }
          }
        },
        "primaryMaster": {
          "type": "object",
          "required": [
            "cellTag"
          ],
          "properties": {
            "cellTag": {
              "description": "Cell tag is an immutable identifier for particular cell of YTsaurus cluster.",
              "type": "integer",
              "maximum": 61440,
              "minimum": 1
            },
            "hostAddresses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "x-kubernetes-list-type": "set"
            }
          }
        },
        "secondaryMasters": {
          "type": "array",
          "maxItems": 48,
          "items": {
            "type": "object",
            "required": [
              "cellTag"
            ],
            "properties": {
              "cellTag": {
                "description": "Cell tag is an immutable identifier for particular cell of YTsaurus cluster.",
                "type": "integer",
                "maximum": 61440,
                "minimum": 1
              },
              "hostAddresses": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "x-kubernetes-list-type": "set"
              }
            }
          }
        }
      },
      "x-kubernetes-validations": [
        {
          "rule": "has(self.cellTag) || (has(self.primaryMaster) \u0026\u0026 has(self.primaryMaster.cellTag))",
          "message": "either cellTag or primaryMaster.cellTag must be set"
        },
        {
          "rule": "!(has(self.cellTag) \u0026\u0026 has(self.primaryMaster) \u0026\u0026 has(self.primaryMaster.cellTag)) || self.cellTag == self.primaryMaster.cellTag",
          "message": "cellTag and primaryMaster.cellTag must match when both are set"
        }
      ]
    },
    "status": {
      "description": "RemoteYtsaurusStatus defines the observed state of RemoteYtsaurus",
      "type": "object"
    }
  }
}